# RAEVTAR Configuration
# Copy to .env and adjust before running.

# ── Server ──────────────────────────────────────────
RAEVTAR_ADDR=:8080              # Listen address
RAEVTAR_DOMAIN=raevtar.tech     # Public domain
RAEVTAR_ENV=                    # Set "production" for stricter checks (no default)
RAEVTAR_LOG_LEVEL=info          # debug | info | warn | error

# ── Auth ────────────────────────────────────────────
RAEVTAR_ADMIN_KEY=changeme-to-something-random  # API key for write endpoints (wajib diisi)
RAEVTAR_ADMIN_USER=admin                         # Admin panel username
RAEVTAR_ADMIN_PASS=changeme-too                  # Admin panel password (wajib diisi di production)

# ── Storage ─────────────────────────────────────────
# RAEVTAR_DB=~/.raevtar/data.db           # SQLite database path
# RAEVTAR_MEDIA_DIR=~/.raevtar/uploads    # Upload directory

# ── Static ──────────────────────────────────────────
# RAEVTAR_STATIC_DIR=./static             # Static files (default: computed from binary path)

# ── Agent ───────────────────────────────────────────
# RAEVTAR_AGENT_DIR=/usr/local/bin        # Agent install directory

# ── Rate Limiting & Throttle ────────────────────────
# RAEVTAR_RATE_LIMIT_REQUESTS=60          # Max requests per window per IP
# RAEVTAR_RATE_LIMIT_WINDOW=60s           # Rate limit window (Go duration)
# RAEVTAR_LOGIN_FAILURE_LIMIT=5           # Max login failures per user/IP
# RAEVTAR_LOGIN_IP_FAILURE_LIMIT=20       # Max login failures per IP

# ── HTTP Timeouts ───────────────────────────────────
# RAEVTAR_READ_TIMEOUT=10s                # HTTP read timeout
# RAEVTAR_WRITE_TIMEOUT=30s               # HTTP write timeout
# RAEVTAR_IDLE_TIMEOUT=60s                # HTTP idle timeout
# RAEVTAR_SHUTDOWN_TIMEOUT=15s            # Graceful shutdown timeout

# ── Upload ──────────────────────────────────────────
# RAEVTAR_MAX_UPLOAD_MB=6                 # Max media upload size in MB

# ── Proxy ───────────────────────────────────────────
# RAEVTAR_TRUSTED_PROXY_CIDRS=            # Comma-separated CIDRs (for CF-Connecting-IP)

# ── System ──────────────────────────────────────────
# RAEVTAR_DISK_ROOT=/                     # Filesystem root for disk stats (macOS/Linux)
