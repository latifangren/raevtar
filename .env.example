# RAEVTAR Configuration
# Copy to .env and adjust

RAEVTAR_ADDR=:8080
RAEVTAR_DOMAIN=raevtar.tech
RAEVTAR_LOG_LEVEL=info
RAEVTAR_ADMIN_KEY=changeme-to-something-random

# Set to "production" for stricter checks
# RAEVTAR_ENV=production

# Database path (default: ~/.raevtar/data.db)
# RAEVTAR_DB=/custom/path/data.db

# Media upload directory (default: ~/.raevtar/uploads)
# RAEVTAR_MEDIA_DIR=/custom/path/uploads
