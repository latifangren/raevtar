{
  "openapi": "3.0.3",
  "info": {
    "title": "Raevtar Public API",
    "description": "Public read-only API for published posts, projects, and categories. Operator and monitoring endpoints are intentionally omitted from this public spec.",
    "version": "1.0.0",
    "contact": {
      "name": "latifangren",
      "url": "https://raevtar.tech"
    }
  },
  "servers": [
    { "url": "/", "description": "Same-origin" }
  ],
  "paths": {
    "/api/v1/posts": {
      "get": {
        "summary": "List published blog posts",
        "description": "Returns published posts only, newest first.",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "description": "Optional category slug filter",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Published posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Post" }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects": {
      "get": {
        "summary": "List published projects",
        "description": "Returns published projects only. Default order is featured first, then manual sort order, then newest first.",
        "parameters": [
          {
            "name": "featured",
            "in": "query",
            "description": "Optional filter to return featured projects only when set to true",
            "required": false,
            "schema": { "type": "boolean" }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Optional ordering override. Supported values: newest, oldest",
            "required": false,
            "schema": { "type": "string", "enum": ["newest", "oldest"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Published projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Project" }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameter"
          }
        }
      }
    },
    "/api/v1/categories": {
      "get": {
        "summary": "List public categories",
        "responses": {
          "200": {
            "description": "Categories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Category" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Post": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "category_id": { "type": "integer" },
          "title": { "type": "string" },
          "slug": { "type": "string" },
          "content_md": { "type": "string" },
          "excerpt": { "type": "string" },
          "published": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "category_name": { "type": "string" },
          "category_slug": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Tag" }
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "slug": { "type": "string" },
          "content_md": { "type": "string" },
          "excerpt": { "type": "string" },
          "cover_image_url": { "type": "string" },
          "published": { "type": "boolean" },
          "featured": { "type": "boolean" },
          "sort_order": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "tags": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Tag" }
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "slug": { "type": "string" }
        }
      }
    }
  }
}
